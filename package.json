{
  "name": "Matching Engine",
  "version": "0.0.1",
  "description": "High-performance matching engine for Web3 lending and borrowing",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "ts-node src/services/main.ts",
    "start:prod": "node dist/services/main.js",
    "test": "jest --silent",
    "test:verbose": "jest --verbose",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "matching-engine",
    "web3",
    "lending",
    "borrowing",
    "defi"
  ],
  "author": "Centuari",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.3.1",
    "functional-red-black-tree": "^1.0.1",
    "ioredis": "^5.8.2",
    "nats": "^2.19.0",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/functional-red-black-tree": "^1.0.2",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
