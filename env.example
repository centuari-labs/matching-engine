# NATS Configuration
# ===================

# NATS server URL(s)
# For multiple servers (clustering), use comma-separated list
# Example: nats://server1:4222,nats://server2:4222
NATS_URL=nats://localhost:4222

# NATS Authentication (optional)
# Use either user/password OR token, not both
NATS_USER=
NATS_PASSWORD=
NATS_TOKEN=

# NATS Connection Options
# Maximum number of reconnection attempts (default: 10)
NATS_MAX_RECONNECT_ATTEMPTS=10

# Time to wait between reconnection attempts in milliseconds (default: 2000)
NATS_RECONNECT_TIME_WAIT=2000

# Connection timeout in milliseconds (default: 10000)
NATS_TIMEOUT=10000

# Redis Configuration
# ====================

# Redis server URL
# Example: redis://localhost:6379
# Example with password: redis://:password@localhost:6379
REDIS_URL=redis://localhost:6379

# Redis Authentication (optional)
REDIS_PASSWORD=

# Redis database number (0-15, default: 0)
REDIS_DB=0

# Redis Connection Options
# Maximum number of reconnection attempts (default: 10)
REDIS_MAX_RECONNECT_ATTEMPTS=10

# Time to wait between reconnection attempts in milliseconds (default: 2000)
REDIS_RECONNECT_TIME_WAIT=2000

# Connection timeout in milliseconds (default: 10000)
REDIS_TIMEOUT=10000

# Enable TLS/SSL connection (default: false)
REDIS_TLS=false

#
# Database Configuration
# ======================
#
# Postgres connection URL
# The backend, settlement engine, and matching engine share the same database.
DB_URL=postgres://user:password@localhost:5432/matching_engine
#
# Maximum number of connections in the pool (default: 10)
DB_MAX_POOL_SIZE=10
#
# Idle timeout for pooled connections in milliseconds (default: 30000)
DB_IDLE_TIMEOUT_MS=30000

# Application Configuration
# =========================

# Node environment (development, production, test)
NODE_ENV=development

# Logging level (optional)
LOG_LEVEL=info

# Fee Configuration
# =================

# Maker fee in basis points (100 bps = 1%, default: 10 for 0.1%)
MAKER_FEE_BPS=10

# Taker fee in basis points (default: 20 for 0.2%)
TAKER_FEE_BPS=20

# Snapshot Configuration
# ======================

# Enable/disable snapshot feature (default: true)
SNAPSHOT_ENABLED=true

# Periodic snapshot interval in seconds (default: 30)
SNAPSHOT_INTERVAL_SECONDS=30

# Directory for snapshot files (default: ./snapshots)
SNAPSHOT_DIR=./snapshots

# Enable Redis as secondary backup for snapshots (default: false)
# Note: Filesystem is always the primary storage, Redis is optional backup
SNAPSHOT_REDIS_ENABLED=false

# Skip restoring from snapshot on startup (default: false)
# When true, matching engine starts with empty order book
SNAPSHOT_RESET_ON_STARTUP=false

# Periodic maturity-expiry sweep interval in seconds (default: 60; 0 disables).
# Removes resting orders whose market has passed maturity and publishes a
# CANCELLED (cancel_reason=MARKET_MATURED) status so the db-writer releases the
# user's locked balance.
ORDER_EXPIRY_SWEEP_INTERVAL_SECONDS=60